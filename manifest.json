{
  "manifest_version": 3,
  "name": "Vocab Master",
  "version": "6.5.0",
  "description": "Vocab Master with redesigned learning lab, Rescue Lane word suggestions, smarter next-word guidance, and learning-first memory rescue.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Vocab Master",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
