{
  "manifest_version": 3,
  "name": "Vocab Master",
  "version": "7.2.0",
  "description": "Vocab Master with Set Doctor, Memory Coach, Retrieval Ladder, Context Replay, and Memory Constellation cluster missions.",
  "permissions": [
    "storage"
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "Open Vocab Master",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png"
    }
  }
}
